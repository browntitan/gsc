# ------------------------------
# Core database / app settings
# ------------------------------
POSTGRES_DB=openwebui
POSTGRES_USER=openwebui
POSTGRES_PASSWORD=openwebui
POSTGRES_PORT=55432
DATABASE_URL=postgresql://openwebui:openwebui@localhost:55432/openwebui

OPENWEBUI_PORT=3001
PIPELINES_PORT=9099

# Use the official quick-start tags for a demo.
# Pin a specific release tag later if you want stricter reproducibility.
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
PIPELINES_IMAGE=ghcr.io/open-webui/pipelines:main

WEBUI_SECRET_KEY=change-this-before-sharing

# ------------------------------
# Local Ollama path (recommended quick demo)
# ------------------------------
# The compose file already maps host.docker.internal -> host-gateway.
# Keep Ollama running on your host at port 11434.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=gpt-oss:20b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Single-pipeline runtime settings
CHUNK_TABLE_NAME=supply_chain_chunks
DEFAULT_COLLECTION_NAME=GSC-Internal-Policy
TOP_K=6
REQUEST_TIMEOUT_SECONDS=120
ROUTER_MODE=extractor_assisted
ENABLE_LLM_EXTRACTOR=true
ENABLE_LLM_FORMATTER=true
EXTRACTOR_TIMEOUT_SECONDS=30

ANSWER_PROVIDER=ollama
ANSWER_MODEL=gpt-oss:20b
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=768
EXTRACTOR_PROVIDER=ollama
EXTRACTOR_MODEL=gpt-oss:20b
FORMATTER_PROVIDER=ollama
FORMATTER_MODEL=gpt-oss:20b

# ------------------------------
# Azure OpenAI option
# ------------------------------
# Azure v1 base URL example:
# https://YOUR-RESOURCE-NAME.openai.azure.com/openai/v1/
AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_MODEL=
AZURE_OPENAI_EMBED_MODEL=

# ------------------------------
# Open WebUI preconfigured OpenAI-compatible connection -> Pipelines
# ------------------------------
PIPELINES_API_KEY=0p3n-w3bu!
OPENAI_API_BASE_URLS=http://pipelines:9099
OPENAI_API_KEYS=0p3n-w3bu!
